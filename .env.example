# =============================================================================
# Environment variable template.
#
# Copy this file to `.env` and adjust the values:   cp .env.example .env
#
# SECURITY RULES:
#   - `.env` is git-ignored and MUST NEVER be committed (it holds real secrets).
#   - This `.env.example` is committed and contains ONLY non-secret placeholders.
#   - In production, set real values via the platform's secret manager / env,
#     never by committing them to the repository.
#
# Variable names map to fields on the Settings class (app/core/config/settings.py)
# case-insensitively. Settings ignores any variables it does not model, so the
# "later phases" block below is documented here but not yet read by the code.
# =============================================================================

# -----------------------------------------------------------------------------
# Phase 1 — active configuration (read by the current code)
# -----------------------------------------------------------------------------

# Application
APP_ENV=development          # development | testing | production
APP_DEBUG=true               # verbose errors + reload; MUST be false in production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Database — async URL is used by the app, sync URL is used by Alembic.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docintell
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/docintell
DB_POOL_SIZE=5               # steady-state pooled connections
DB_MAX_OVERFLOW=10           # extra connections allowed under load
DB_ECHO=false                # log every SQL statement (debugging only)

# Authentication / security  (utilities exist in Phase 1; login flow is later)
# SECURITY: this placeholder is fine for local dev, but the app REFUSES TO START
# when APP_ENV=production while this default is still set. Generate a strong,
# random value for production, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Later phases — placeholders (documented now, not yet read by the code)
# -----------------------------------------------------------------------------

# Redis (Celery broker + rate limiting) — Phase 2
# REDIS_URL=redis://localhost:6379/0

# OpenAI (LLM analysis / optional embeddings) — Phase 3+
# OPENAI_API_KEY=sk-your-key-here

# Embeddings — Phase 3+
# EMBEDDING_PROVIDER=sentence-transformer   # sentence-transformer | openai
# EMBEDDING_MODEL=all-MiniLM-L6-v2          # OpenAI: text-embedding-3-small
# EMBEDDING_DIMENSION=384                    # OpenAI text-embedding-3-small: 1536

# Document processing — Phase 2+
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64
# MAX_FILE_SIZE_MB=50

# Storage — Phase 2+
# STORAGE_BACKEND=local                      # local | s3
# STORAGE_PATH=./uploads
